# DashScope API Key for ASR (Bilibili videos without subtitles)
# Get your key from: https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=your_key_here

# Bilibili SESSDATA cookie (optional)
# The program can auto-extract this from Chrome/Safari on first run.
# Set it manually only if you prefer not to use browser cookie extraction.
BILIBILI_SESSDATA=
